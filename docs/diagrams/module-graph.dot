digraph x64lens_modules {
  rankdir=LR;
  node [shape=box];

  main -> cli;
  main -> version;
  main -> info;
  cli -> print;
  version -> print;
  info -> filemap;
  info -> elf64;
  info -> report_text;
  info -> errors;
  filemap -> syscalls;
  elf64 -> bounds;
  errors -> print;
  report_text -> print;
  report_text -> hex;
  hex -> print;

  elf64 -> phdr [label="Sprint 2"];
  phdr -> regions;
  regions -> scanner [label="Sprint 3"];
  scanner -> patterns;
  patterns -> classifier [label="Sprint 4"];
  classifier -> scoring [label="Sprint 5"];
  scoring -> report_text;
  scoring -> report_json;
}
