digraph x64lens_modules {
  rankdir=LR;
  node [shape=box];

  main -> cli;
  main -> info;
  main -> mitigations;

  info -> filemap;
  info -> elf64;
  info -> report_text;
  info -> errors;

  mitigations -> filemap;
  mitigations -> elf64;
  mitigations -> phdr;
  mitigations -> report_text;
  mitigations -> errors;

  phdr -> bounds;
  phdr -> regions;

  filemap -> syscalls;
  elf64 -> bounds;
  report_text -> print;
  report_text -> hex;
  errors -> print;

  scanner -> patterns;
  patterns -> classifier;
  classifier -> scoring;
  scoring -> report_text;
  scoring -> report_json;
}
