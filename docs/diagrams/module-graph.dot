digraph x64lens_modules {
  rankdir=LR;
  node [shape=box];

  main -> cli;
  main -> info;
  main -> mitigations;
  main -> gadgets;

  info -> filemap;
  info -> elf64;
  info -> report_text;
  info -> errors;

  mitigations -> filemap;
  mitigations -> elf64;
  mitigations -> phdr;
  mitigations -> report_text;
  mitigations -> errors;

  gadgets -> filemap;
  gadgets -> elf64;
  gadgets -> phdr;
  gadgets -> scanner;
  gadgets -> patterns;
  gadgets -> classifier;
  gadgets -> report_text;
  gadgets -> errors;

  phdr -> bounds;
  phdr -> regions;
  scanner -> regions;
  patterns -> scanner;
  classifier -> patterns;

  filemap -> syscalls;
  elf64 -> bounds;
  report_text -> print;
  report_text -> hex;
  errors -> print;

  scoring -> classifier;
  scoring -> report_text;
  scoring -> report_json;
}
