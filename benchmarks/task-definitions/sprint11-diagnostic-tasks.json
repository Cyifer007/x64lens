      "insufficient_relation_evidence"
    ],
    "late_input_reauthentication": true,
    "atomic_output_commit_with_postcommit_reauthentication": true
  },
  "normalized_relations": [
    {
      "id": "executable_return_byte_presence",
      "status": "unavailable",
      "scope": "cross_tool_raw_byte",
      "reason": "ROPgadget, Ropper, and ropr expose decoder-backed gadget records rather than a program-header-authoritative raw executable-byte observation. No baseline-native total is substituted for this relation.",
      "substitution_allowed": false
    },
    {
      "id": "tool_reported_return_terminator_records",
      "scope": "tool_specific",
      "comparison_rule": "Retain and label each baseline's own return-terminated records. Tool-native totals are not cross-tool gadget populations.",
      "status": "implemented"
    },
    {
      "id": "canonical_exact_pop_rdi_ret",
      "scope": "cross_tool_exact_relation",
      "comparison_key": [
        "address",
        "instructions"
      ],
      "canonical_instructions": [
        "pop rdi",
        "ret"
      ],
      "comparison_rule": "Compare only an exact two-instruction pop-rdi-return relation emitted by the named baseline. This does not become an x64lens semantic-exact or decoder-backed population.",
      "status": "implemented"
    },
    {
      "id": "binary_fact_arg_control_rdi_present",
      "scope": "binary_fact",
      "comparison_rule": "True when the baseline native output contains at least one canonical_exact_pop_rdi_ret relation.",
      "status": "implemented"
    }
  ],
  "tasks": [
    {
      "id": "core_scanner",
      "status": "unavailable",
      "task_scope": "core_scanner",
      "reason": "The public CLI has no report-suppressed scanner-only path. Text or JSON report timing is not a truthful substitute for isolated scanner cost.",
      "substitution_allowed": false,
      "decision_owner": "diagnostic evidence and a reviewed instrumentation seam"
    },
    {
      "id": "x64lens_gadget_json",
      "status": "implemented",
      "task_scope": "gadget_report",
      "condition_id": "x64lens-gadget-json",
      "command_template": [
        "x64lens",
        "gadgets",
        "--format",
        "json",
        "--max-depth",
        "4",
        "<target>"
      ],
      "extractor": "x64lens_json_0_2",
      "parity_group": "x64lens-schema-0.2-command-identity",
      "work_scope_note": "Runs the complete current analysis pipeline and JSON adapter.",
      "condition_id_rule": "base_or_base--target_id"
    },
    {
      "id": "x64lens_integrated_analysis_json",
      "status": "implemented",
      "task_scope": "integrated_analysis",
      "condition_id": "x64lens-analysis-json",
      "command_template": [
        "x64lens",
        "analyze",
        "--format",
        "json",
        "--max-depth",
        "4",
        "<target>"
      ],
      "extractor": "x64lens_json_0_2",
      "parity_group": "x64lens-schema-0.2-command-identity",
      "work_scope_note": "Current JSON output shares the same report body and analysis facts as gadgets; the command identity differs, so this is not yet an independently broader workload.",
      "condition_id_rule": "base_or_base--target_id"
    }
  ],
  "baselines": [
    {
      "id": "ropgadget",
      "status": "implemented",
      "task_scope": "baseline_gadget_report",
      "condition_id": "ropgadget-rop-report",
      "executable_name": "ROPgadget",
      "version_command_template": [
        "<tool>",
        "--version"
      ],
      "command_template": [
        "<tool>",
        "--binary",
        "<target>",
        "--depth",
        "5",
        "--only",
        "pop|ret",
        "--nojop",
        "--nosys"
