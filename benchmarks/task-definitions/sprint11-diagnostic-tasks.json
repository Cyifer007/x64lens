    "artifact_schema_version": 1,
    "required_roles": [
      {
        "id": "et_exec",
        "artifact_id": "exec-nopie",
        "elf_type": "ET_EXEC"
      },
      {
        "id": "pie_et_dyn",
        "artifact_id": "exec-pie",
        "elf_type": "ET_DYN"
      },
      {
        "id": "shared_et_dyn",
        "artifact_id": "shared",
        "elf_type": "ET_DYN"
      }
    ],
