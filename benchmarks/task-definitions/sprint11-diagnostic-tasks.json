        "stream": "stdout",
        "format": "address-colon-semicolon-instruction-text",
        "require_utf8": true,
        "ansi_policy": "strip-and-count",
        "require_return_terminated": true,
        "uncategorized_line_policy": "reject",
        "maximum_line_bytes": 8192,
        "maximum_record_count": 262144,
        "maximum_instruction_count": 5,
        "maximum_line_bytes_scope": "raw_bytes_before_ansi_normalization",
        "return_alias_policy": {
          "retq": "ret"
        }
      },
      "adapter": {
        "id": "x64lens-sprint11-baseline-output-adapter-v2",
