{
  "schema_version": 3,
  "authority_id": "sprint11-diagnostic-task-definitions-v3",
  "evidence_class": "diagnostic",
  "frozen": false,
  "publication_eligible": false,
  "reference_profile": "core-1w",
  "campaign_freeze_sprint": 15,
  "adapter_policy": {
    "adapter_id": "x64lens-sprint11-baseline-output-adapter-v2",
    "adapter_path": "benchmarks/scripts/baseline-output-adapter.py",
    "native_output_retained": true,
    "uncategorized_output_policy": "reject",
    "duplicate_policy": "preserve every native record and report tool-specific record, unique-record, and duplicate-record totals",
    "canonicalization_policy": "lowercase and whitespace-normalize instruction text; preserve native sequence and source line; canonicalize addresses as 16-digit hexadecimal strings",
    "analysis_authority": false,
    "late_input_reauthentication": true,
    "adapter_schema_version": 2,
    "campaign_row_binding_required": true,
    "raw_line_limit_applied_before_ansi_normalization": true,
    "atomic_output_commit_with_postcommit_reauthentication": true,
    "canonical_return_aliases": {
      "retq": "ret"
    }
  },
  "x64lens_relation_policy": {
    "extractor_id": "x64lens-sprint11-relation-extractor-v1",
    "extractor_path": "benchmarks/scripts/x64lens-relation-extractor.py",
    "artifact_schema_version": 1,
    "runner_extractor": "x64lens_json_0_2",
    "report_schema_version": "0.2.0",
    "report_command": "gadgets",
    "campaign_row_binding_required": true,
    "measured_phase_required": true,
    "normalized_relation_ids": [
      "canonical_exact_pop_rdi_ret",
      "binary_fact_arg_control_rdi_present"
    ],
    "address_coordinates": [
      "virtual_address_start",
