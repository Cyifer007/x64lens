      "file_offset_start",
      "file_offset_terminator"
    ],
    "late_input_reauthentication": true,
    "atomic_output_commit_with_postcommit_reauthentication": true
  },
  "runtime_closure_policy": {
    "generator_id": "x64lens-sprint11-runtime-closure-v1",
    "generator_path": "benchmarks/scripts/runtime-closure-manifest.py",
    "artifact_schema_version": 1,
    "campaign_row_binding_required": true,
    "measured_phase_required": true,
    "closure_modes": [
      "native_elf",
      "python_console_entrypoint",
      "script_interpreter"
    ],
    "python_observation": "retained version command under declared shebang interpreter with imported module, distribution, extension, and mapped native-library capture",
    "native_observation": "bounded recursive DT_NEEDED and PT_INTERP closure using authenticated readelf and ldconfig identities",
    "completeness_states": [
      "complete",
      "partial"
    ],
    "late_input_reauthentication": true,
    "atomic_output_commit_with_postcommit_reauthentication": true
  },
  "address_coordinate_policy": {
    "calibrator_id": "x64lens-sprint11-address-coordinate-calibrator-v1",
