{
  "name": "x64lens-dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/work",
  "remoteUser": "ubuntu",
  "updateRemoteUserUID": true,
  "containerEnv": {
    "HOME": "/home/ubuntu"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "bierner.markdown-mermaid",
        "yzhang.markdown-all-in-one"
      ]
    }
  },
  "postCreateCommand": "make scaffold-check || true"
}
