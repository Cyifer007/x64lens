@@ -0,0 +1,1356 @@
+#!/usr/bin/env python3
+"""Run provenance-bound Sprint 11 diagnostic benchmark conditions.
+
+The runner is development and research infrastructure, not a runtime dependency
+of x64lens. It uses only Python's standard library, snapshots immutable tool and
+target bytes, measures each process with monotonic nanosecond timing and Linux
+wait4 resource data, retains failed rows, and publishes one complete campaign
+tree transactionally.
+"""
+
+from __future__ import annotations
+
+import argparse
+import csv
+import ctypes
+from datetime import datetime, timezone
+import errno
+import hashlib
+import json
+import math
+import os
+from pathlib import Path
+import platform
+import re
+import resource
+import shutil
+import signal
+import statistics
+import stat
+import subprocess
+import sys
+import time
+from typing import Any, Iterable
+import uuid
+
+RUNNER_SCHEMA_VERSION = 1
+EVIDENCE_CLASS = "diagnostic"
+PUBLICATION_ELIGIBLE = False
+SAFE_ID = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$")
+SAFE_ENV = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")
+TASK_SCOPES = {
+    "core_scanner",
+    "gadget_report",
+    "integrated_analysis",
+    "baseline_gadget_report",
+    "mitigation_metadata",
+}
+EXTRACTORS = {"none", "x64lens_json_0_2"}
+ORDER_POLICIES = {"listed", "alternating"}
+CACHE_POLICIES = {"warm", "uncontrolled"}
+RESERVED_ENVIRONMENT_KEYS = {
+    "HOME",
+    "TMPDIR",
