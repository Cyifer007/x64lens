{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/x64lens-report-0.2.0.schema.json",
  "title": "x64lens report schema 0.2.0",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "tool_version",
    "report_type",
    "command",
    "analysis",
    "target",
    "mitigations",
    "counts",
    "primitive_coverage",
    "gadgets",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "0.2.0"
    },
    "tool": {
      "const": "x64lens"
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "report_type": {
      "const": "analysis"
    },
    "command": {
      "type": "string",
      "enum": [
        "gadgets",
        "analyze"
      ]
    },
    "analysis": {
      "type": "object",
      "required": [
        "complete",
        "max_depth",
        "candidate_capacity",
        "candidate_count",
        "candidate_truncated",
        "candidate_dropped_count",
        "candidate_dropped_count_known",
        "regions_scanned",
        "regions_total"
      ],
      "properties": {
        "complete": {
          "const": true
        },
        "max_depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "candidate_capacity": {
          "type": "integer",
          "minimum": 1
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "candidate_truncated": {
          "const": false
        },
        "candidate_dropped_count": {
          "const": 0
        },
        "candidate_dropped_count_known": {
          "const": true
        },
        "regions_scanned": {
          "type": "integer",
          "minimum": 0
        },
        "regions_total": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "target": {
      "type": "object",
      "required": [
        "path",
        "format",
        "arch",
        "file_size",
        "entry"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "const": "ELF64"
        },
        "arch": {
          "const": "x86_64"
        },
        "file_size": {
          "type": "integer",
          "minimum": 1
        },
        "entry": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{16}$"
        }
      },
      "additionalProperties": true
    },
    "mitigations": {
      "type": "object",
      "properties": {
        "nx_stack": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "pie": {
          "type": "boolean"
        },
        "relro": {
          "type": "string",
          "enum": [
            "none",
            "partial",
            "full"
          ]
        },
        "rwx_load_segment": {
          "type": "boolean"
        },
        "dynamic_linking": {
          "type": "boolean"
        },
        "bind_now": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "dynamic_entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "dynamic_terminated": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "canary": {
          "type": "string",
          "enum": [
            "unknown",
            "absent",
            "present"
          ]
        },
        "stripped": {
          "type": "string",
          "enum": [
            "unknown",
            "stripped",
            "not_stripped"
          ]
        }
      },
      "additionalProperties": true,
      "required": [
        "nx_stack",
        "pie",
        "relro",
        "canary",
        "rwx_load_segment",
        "dynamic_linking",
        "bind_now",
        "dynamic_entry_count",
        "dynamic_terminated"
      ]
    },
    "counts": {
      "type": "object",
      "properties": {
        "raw_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "ret_count": {
          "type": "integer",
          "minimum": 0
        },
        "ret_imm16_count": {
          "type": "integer",
          "minimum": 0
        },
        "exact_pattern_count": {
          "type": "integer",
          "minimum": 0
        },
        "semantic_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "unknown_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "scored_candidate_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true,
      "required": [
        "raw_candidate_count",
        "ret_count",
        "ret_imm16_count",
        "exact_pattern_count",
        "semantic_candidate_count",
        "unknown_candidate_count",
        "scored_candidate_count"
      ]
    },
    "primitive_coverage": {
      "type": "object",
      "properties": {
        "arg_control": {
          "type": "boolean"
        },
        "syscall_num_control": {
          "type": "boolean"
        },
        "syscall_trigger": {
          "type": "boolean"
        },
        "stack_pivot": {
          "type": "boolean"
        },
        "alignment": {
          "type": "boolean"
        },
        "reg_transfer": {
          "type": "boolean"
        },
        "registers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "rax",
              "rbx",
              "rcx",
              "rdx",
              "rsi",
              "rdi",
              "rbp",
              "rsp",
              "r8",
              "r9",
              "r10",
              "r11",
              "r12",
              "r13",
              "r14",
              "r15"
            ]
          },
          "uniqueItems": true
        },
        "memory_write": {
          "type": "boolean"
        },
        "memory_read": {
          "type": "boolean"
        }
      },
      "additionalProperties": true,
      "required": [
        "arg_control",
        "syscall_num_control",
        "syscall_trigger",
        "stack_pivot",
        "alignment",
        "registers"
      ]
    },
    "gadgets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "va",
          "file_offset",
          "bytes",
          "terminator",
          "pattern",
          "semantic_class",
          "controls",
          "stack_delta",
          "stack_delta_known",
          "score"
        ],
        "properties": {
          "va": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]{16}$"
          },
          "file_offset": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]{16}$"
          },
          "bytes": {
            "type": "string",
            "pattern": "^(?:[0-9a-fA-F]{2})+$"
          },
          "terminator": {
            "type": "string",
            "enum": [
              "ret",
              "ret imm16",
              "unknown"
            ]
          },
          "pattern": {
            "type": "string",
            "minLength": 1
          },
          "semantic_class": {
            "type": "string",
            "enum": [
              "unknown_candidate",
              "arg_control",
              "syscall_num_control",
              "syscall_trigger",
              "stack_pivot",
              "memory_write",
              "memory_read",
              "reg_transfer",
              "alignment",
              "clobber_heavy"
            ]
          },
          "controls": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "rax",
                "rbx",
                "rcx",
                "rdx",
                "rsi",
                "rdi",
                "rbp",
                "rsp",
                "r8",
                "r9",
                "r10",
                "r11",
                "r12",
                "r13",
                "r14",
                "r15"
              ]
            },
            "uniqueItems": true
          },
          "stack_pop_order": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "rax",
                "rbx",
                "rcx",
                "rdx",
                "rsi",
                "rdi",
                "rbp",
                "rsp",
                "r8",
                "r9",
                "r10",
                "r11",
                "r12",
                "r13",
                "r14",
                "r15"
              ]
            },
            "maxItems": 8,
            "description": "Exact pop-register order for the recognized suffix; empty when no pop sequence is represented."
          },
          "register_transfer": {
            "type": [
              "object",
              "null"
            ],
            "description": "Exact source/destination relation for a supported register-direct transfer; null for other candidates.",
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "rax",
                  "rbx",
                  "rcx",
                  "rdx",
                  "rsi",
                  "rdi",
                  "rbp",
                  "rsp",
                  "r8",
                  "r9",
                  "r10",
                  "r11",
                  "r12",
                  "r13",
                  "r14",
                  "r15"
                ]
              },
              "destination": {
                "type": "string",
                "enum": [
                  "rax",
                  "rbx",
                  "rcx",
                  "rdx",
                  "rsi",
                  "rdi",
                  "rbp",
                  "rsp",
                  "r8",
                  "r9",
                  "r10",
                  "r11",
                  "r12",
                  "r13",
                  "r14",
                  "r15"
                ]
              }
            },
            "required": [
              "source",
              "destination"
            ],
            "additionalProperties": false
          },
          "clobbers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "rax",
                "rbx",
                "rcx",
                "rdx",
                "rsi",
                "rdi",
                "rbp",
                "rsp",
                "r8",
                "r9",
                "r10",
                "r11",
                "r12",
                "r13",
                "r14",
                "r15"
              ]
            },
            "uniqueItems": true,
            "description": "Registers known to be clobbered by the represented semantic rule."
          },
          "side_effects": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "stack_read",
                "stack_pivot",
                "syscall",
                "ret_imm16",
                "register_write",
                "stack_adjust",
                "flags_write",
                "memory_read",
                "memory_write"
              ]
            },
            "uniqueItems": true,
            "description": "Explicit side-effect facts produced by the classifier."
          },
          "stack_delta": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "stack_delta_known": {
            "type": "boolean"
          },
          "score": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0,
            "maximum": 100
          },
          "section": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence": {
            "type": "object",
            "required": [
              "kind",
              "raw_candidate",
              "exact_suffix",
              "semantic_source",
              "validator",
              "matched_suffix_offset",
              "matched_suffix_length",
              "full_sequence_valid"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "raw_only",
                  "exact_suffix",
                  "semantic_exact",
                  "decoder_validated",
                  "semantic_decoded"
                ]
              },
              "raw_candidate": {
                "const": true
              },
              "exact_suffix": {
                "type": "boolean"
              },
              "semantic_source": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  null,
                  "exact",
                  "decoded"
                ]
              },
              "validator": {
                "type": "string",
                "enum": [
                  "x64lens-raw-scanner",
                  "x64lens-exact-suffix",
                  "x64lens-decoder"
                ]
              },
              "matched_suffix_offset": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0
              },
              "matched_suffix_length": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 1
              },
              "full_sequence_valid": {
                "type": [
                  "boolean",
                  "null"
                ]
              }
            },
            "additionalProperties": true,
            "allOf": [
              {
                "if": {
                  "properties": {
                    "exact_suffix": {
                      "const": true
                    }
                  },
                  "required": [
                    "exact_suffix"
                  ]
                },
                "then": {
                  "properties": {
                    "matched_suffix_offset": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "matched_suffix_length": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                },
                "else": {
                  "properties": {
                    "matched_suffix_offset": {
                      "type": "null"
                    },
                    "matched_suffix_length": {
                      "type": "null"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "kind": {
                      "const": "raw_only"
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                "then": {
                  "properties": {
                    "exact_suffix": {
                      "const": false
                    },
                    "semantic_source": {
                      "type": "null"
                    },
                    "validator": {
                      "const": "x64lens-raw-scanner"
                    },
                    "full_sequence_valid": {
                      "type": "null"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "kind": {
                      "const": "exact_suffix"
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                "then": {
                  "properties": {
                    "exact_suffix": {
                      "const": true
                    },
                    "semantic_source": {
                      "type": "null"
                    },
                    "validator": {
                      "const": "x64lens-exact-suffix"
                    },
                    "full_sequence_valid": {
                      "type": "null"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "kind": {
                      "const": "semantic_exact"
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                "then": {
                  "properties": {
                    "exact_suffix": {
                      "const": true
                    },
                    "semantic_source": {
                      "const": "exact"
                    },
                    "validator": {
                      "const": "x64lens-exact-suffix"
                    },
                    "full_sequence_valid": {
                      "type": "null"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "kind": {
                      "const": "decoder_validated"
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                "then": {
                  "properties": {
                    "validator": {
                      "const": "x64lens-decoder"
                    },
                    "full_sequence_valid": {
                      "type": "boolean"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "kind": {
                      "const": "semantic_decoded"
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                "then": {
                  "properties": {
                    "semantic_source": {
                      "const": "decoded"
                    },
                    "validator": {
                      "const": "x64lens-decoder"
                    },
                    "full_sequence_valid": {
                      "const": true
                    }
                  }
                }
              }
            ]
          },
          "memory_access": {
            "type": [
              "object",
              "null"
            ],
            "description": "Structured facts for a supported bounded memory-read or memory-write suffix; null for other candidates.",
            "properties": {
              "direction": {
                "type": "string",
                "enum": [
                  "read",
                  "write"
                ]
              },
              "base": {
                "type": "string",
                "enum": [
                  "rax",
                  "rbx",
                  "rcx",
                  "rdx",
                  "rsi",
                  "rdi",
                  "rbp",
                  "rsp",
                  "r8",
                  "r9",
                  "r10",
                  "r11",
                  "r12",
                  "r13",
                  "r14",
                  "r15"
                ]
              },
              "index": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  null,
                  "rax",
                  "rbx",
                  "rcx",
                  "rdx",
                  "rsi",
                  "rdi",
                  "rbp",
                  "rsp",
                  "r8",
                  "r9",
                  "r10",
                  "r11",
                  "r12",
                  "r13",
                  "r14",
                  "r15"
                ]
              },
              "scale": {
                "type": "integer",
                "enum": [
                  1,
                  2,
                  4,
                  8
                ]
              },
              "displacement": {
                "type": "integer"
              },
              "displacement_known": {
                "type": "boolean"
              },
              "width_bytes": {
                "type": "integer",
                "minimum": 1
              },
              "value_register": {
                "type": "string",
                "enum": [
                  "rax",
                  "rbx",
                  "rcx",
                  "rdx",
                  "rsi",
                  "rdi",
                  "rbp",
                  "rsp",
                  "r8",
                  "r9",
                  "r10",
                  "r11",
                  "r12",
                  "r13",
                  "r14",
                  "r15"
                ]
              },
              "dereference": {
                "type": "boolean"
              }
            },
            "required": [
              "direction",
              "base",
              "index",
              "scale",
              "displacement",
              "displacement_known",
              "width_bytes",
              "value_register",
              "dereference"
            ],
            "additionalProperties": false
          }
        },
        "additionalProperties": true,
        "allOf": [
          {
            "if": {
              "properties": {
                "stack_delta_known": {
                  "const": true
                }
              },
              "required": [
                "stack_delta_known"
              ]
            },
            "then": {
              "properties": {
                "stack_delta": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            },
            "else": {
              "properties": {
                "stack_delta": {
                  "type": "null"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "semantic_class": {
                  "const": "unknown_candidate"
                }
              },
              "required": [
                "semantic_class"
              ]
            },
            "then": {
              "properties": {
                "score": {
                  "type": "null"
                }
              }
            }
          }
        ]
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "additionalProperties": true,
  "$comment": "Current x64lens schema 0.2.0. Patch 040 reports without per-candidate evidence remain valid; the current producer adds optional evidence objects and the bundled validator enforces current-producer provenance plus arithmetic cross-field invariants.",
  "allOf": [
    {
      "if": {
        "properties": {
          "mitigations": {
            "properties": {
              "dynamic_linking": {
                "const": false
              }
            },
            "required": [
              "dynamic_linking"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "mitigations": {
            "properties": {
              "bind_now": {
                "type": "null"
              },
              "dynamic_terminated": {
                "type": "null"
              },
              "dynamic_entry_count": {
                "const": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mitigations": {
            "properties": {
              "relro": {
                "const": "full"
              }
            },
            "required": [
              "relro"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "mitigations": {
            "properties": {
              "dynamic_linking": {
                "const": true
              },
              "bind_now": {
                "const": true
              }
            },
            "required": [
              "dynamic_linking",
              "bind_now"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "analysis": {
            "properties": {
              "candidate_dropped_count_known": {
                "const": true
              }
            },
            "required": [
              "candidate_dropped_count_known"
            ]
          }
        },
        "required": [
          "analysis"
        ]
      },
      "then": {
        "properties": {
          "analysis": {
            "properties": {
              "candidate_dropped_count": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "analysis": {
            "properties": {
              "candidate_dropped_count_known": {
                "const": false
              }
            },
            "required": [
              "candidate_dropped_count_known"
            ]
          }
        },
        "required": [
          "analysis"
        ]
      },
      "then": {
        "properties": {
          "analysis": {
            "properties": {
              "candidate_dropped_count": {
                "type": "null"
              }
            }
          }
        }
      }
    }
  ]
}
