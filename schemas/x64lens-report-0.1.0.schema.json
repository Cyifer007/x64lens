{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/x64lens-report-0.1.0.schema.json",
  "title": "x64lens report schema",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "tool_version",
    "target",
    "mitigations",
    "counts",
    "primitive_coverage",
    "gadgets",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "tool": {
      "const": "x64lens"
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "object",
      "required": [
        "path",
        "format",
        "arch",
        "file_size",
        "entry"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "const": "ELF64"
        },
        "arch": {
          "const": "x86_64"
        },
        "file_size": {
          "type": "integer",
          "minimum": 1
        },
        "entry": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{16}$"
        }
      },
      "additionalProperties": true
    },
    "mitigations": {
      "type": "object",
      "properties": {
        "nx_stack": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "pie": {
          "type": "boolean"
        },
        "relro": {
          "type": "string",
          "enum": [
            "none",
            "partial",
            "full"
          ]
        },
        "rwx_load_segment": {
          "type": "boolean"
        },
        "dynamic_linking": {
          "type": "boolean"
        },
        "bind_now": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "dynamic_entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "dynamic_terminated": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "canary": {
          "type": "string",
          "enum": [
            "unknown",
            "absent",
            "present"
          ]
        },
        "stripped": {
          "type": "string",
          "enum": [
            "unknown",
            "stripped",
            "not_stripped"
          ]
        }
      },
      "additionalProperties": true,
      "required": [
        "nx_stack",
        "pie",
        "relro",
        "canary",
        "rwx_load_segment",
        "dynamic_linking",
        "bind_now",
        "dynamic_entry_count",
        "dynamic_terminated"
      ]
    },
    "counts": {
      "type": "object",
      "properties": {
        "raw_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "ret_count": {
          "type": "integer",
          "minimum": 0
        },
        "ret_imm16_count": {
          "type": "integer",
          "minimum": 0
        },
        "exact_pattern_count": {
          "type": "integer",
          "minimum": 0
        },
        "semantic_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "unknown_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "scored_candidate_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true,
      "required": [
        "raw_candidate_count",
        "ret_count",
        "ret_imm16_count",
        "exact_pattern_count",
        "semantic_candidate_count",
        "unknown_candidate_count",
        "scored_candidate_count"
      ]
    },
    "primitive_coverage": {
      "type": "object",
      "properties": {
        "arg_control": {
          "type": "boolean"
        },
        "syscall_num_control": {
          "type": "boolean"
        },
        "syscall_trigger": {
          "type": "boolean"
        },
        "stack_pivot": {
          "type": "boolean"
        },
        "alignment": {
          "type": "boolean"
        },
        "registers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true,
      "required": [
        "arg_control",
        "syscall_num_control",
        "syscall_trigger",
        "stack_pivot",
        "alignment",
        "registers"
      ]
    },
    "gadgets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "va",
          "file_offset",
          "bytes",
          "terminator",
          "pattern",
          "semantic_class",
          "controls",
          "stack_delta",
          "stack_delta_known",
          "score"
        ],
        "properties": {
          "va": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]{16}$"
          },
          "file_offset": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]{16}$"
          },
          "bytes": {
            "type": "string"
          },
          "terminator": {
            "type": "string",
            "enum": [
              "ret",
              "ret imm16",
              "unknown"
            ]
          },
          "pattern": {
            "type": "string"
          },
          "semantic_class": {
            "type": "string",
            "enum": [
              "unknown_candidate",
              "arg_control",
              "syscall_num_control",
              "syscall_trigger",
              "stack_pivot",
              "memory_write",
              "memory_read",
              "reg_transfer",
              "alignment",
              "clobber_heavy"
            ]
          },
          "controls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "stack_delta": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "stack_delta_known": {
            "type": "boolean"
          },
          "score": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "section": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true,
  "$comment": "Historical x64lens schema 0.1.0 retained for compatibility validation. Current reports use schemas/x64lens-report.schema.json.",
  "allOf": [
    {
      "if": {
        "properties": {
          "mitigations": {
            "properties": {
              "dynamic_linking": {
                "const": false
              }
            },
            "required": [
              "dynamic_linking"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "mitigations": {
            "properties": {
              "bind_now": {
                "type": "null"
              },
              "dynamic_terminated": {
                "type": "null"
              },
              "dynamic_entry_count": {
                "const": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mitigations": {
            "properties": {
              "relro": {
                "const": "full"
              }
            },
            "required": [
              "relro"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "mitigations": {
            "properties": {
              "dynamic_linking": {
                "const": true
              },
              "bind_now": {
                "const": true
              }
            },
            "required": [
              "dynamic_linking",
              "bind_now"
            ]
          }
        }
      }
    }
  ]
}
